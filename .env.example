# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# PayPal Configuration
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your_paypal_client_id_here

# App Configuration
# Producción: mantén la URL de Vercel (NO uses el dominio de email aquí)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ENV=development

# Cron & Email (drip emails)
CRON_SECRET=your_cron_secret_here
RESEND_API_KEY=your_resend_api_key_here
# Dominio verificado en Resend (solo remitente; la app sigue en NEXT_PUBLIC_APP_URL)
RESEND_FROM_EMAIL=Henry - Gestor de Créditos <hola@mail.ingresosonlinehoy.com>

# Hotmart Webhook
HOTMART_WEBHOOK_SECRET=your_hotmart_webhook_secret_here

# Google Analytics & Ads
NEXT_PUBLIC_GTM_ID=your_gtm_id_here
NEXT_PUBLIC_GA_MEASUREMENT_ID=your_ga_measurement_id_here
NEXT_PUBLIC_GOOGLE_ADS_ID=your_google_ads_id_here
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_SIGNUP=your_signup_conversion_id_here
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_PURCHASE=your_purchase_conversion_id_here
